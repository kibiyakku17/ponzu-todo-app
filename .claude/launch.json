  "version": "0.0.1",
  "configurations": [
    {
      "name": "ponzu-todo",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path'),f=path.join('C:/Users/shouk/OneDrive/Documents/GitHub/ponzu-todo-app',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(f);const ct={'html':'text/html','js':'application/javascript','json':'application/json','css':'text/css'}[ext.slice(1)]||'text/plain';res.writeHead(200,{'Content-Type':ct});res.end(d);}});}).listen(8765)"],
      "port": 8765
    }
  ]
}
